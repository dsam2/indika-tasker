generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  name          String?
  username      String?   @unique
  email    String @unique
  password String
  role     String @default("user")
  tasks    Task[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  userId      String
  completed   Boolean   @default(false)
  priority  String   @default("MISSION")
  createdAt   DateTime  @default(now())
  description String?
  dueDate     DateTime?
  user        User      @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  USER
}
